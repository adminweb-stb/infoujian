# ============================================================
# SECURITY & PROFESSIONAL ARCHITECTURE - Jadwal Ujian Online
# ============================================================

Options -Indexes
RewriteEngine On
RewriteBase /

# --- 1. CLEAN SEO URLS ---

# Map root to index.html (already default, but good to be explicit)
DirectoryIndex index.html

# Admin Panel: Serve panel/index.php when accessing /panel/
# This allows http://localhost/ujian/panel/ to work directly.
RewriteRule ^panel/$ panel/index.php [L]

# Mapping for the new panel structure (no extensions)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^panel/([^/]+)$ panel/$1.php [L]

# Specific mappings for consistency (all point to panel/index.php or their respective files)
RewriteRule ^panel/dashboard$ panel/index.php [L]
RewriteRule ^panel/logger$ panel/logger.php [L]
RewriteRule ^panel/logs$ panel/logs.php [L]
RewriteRule ^panel/import$ panel/import.php [L]
RewriteRule ^panel/sync$ panel/sync.php [L]

# --- 2. SECURITY & CLOAKING ---

# Block direct access to the CORE folder (jantung sistem)
RewriteRule ^core/ - [R=404,L]

# Force 404 status for direct DB access or internal sync scripts
RewriteRule ^(core/db\.php|panel/sync\.php|panel/import\.php)$ /404.html [R=404,L]

# Block sensitive extensions
<FilesMatch "\.(log|sql|env|bak|old|lama|csv)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Exception: Allow the CSV template
<Files "template_jadwal.csv">
    Allow from all
</Files>

# --- 3. SECURITY HEADERS ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- 4. GZIP COMPRESSION ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/json application/javascript
</IfModule>

# --- 5. BROWSER CACHING ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/json "access plus 5 minutes"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/png "access plus 1 month"
</IfModule>

# --- 6. CUSTOM ERROR HANDLING (403/404) ---
ErrorDocument 403 /404.html
ErrorDocument 404 /404.html
